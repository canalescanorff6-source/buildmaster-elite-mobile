# Contas e licenças — valores públicos inseridos no APK durante o build
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_PUBLICA_ANON_OU_PUBLISHABLE

# Produção: mantenha 0. O modo local só deve ser ligado temporariamente em um APK de teste.
NEXT_PUBLIC_BUILDMASTER_ALLOW_LOCAL_FALLBACK=0

# Fallback local temporário. Só funciona quando explicitamente ativado e nunca deve ser distribuído.
NEXT_PUBLIC_BUILDMASTER_LOCAL_ADMIN_USER=seu_usuario_admin
NEXT_PUBLIC_BUILDMASTER_LOCAL_ADMIN_PASSWORD=troque-esta-senha
