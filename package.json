{
  "name": "buildmaster-elite-mobile-rn-v1-3-apk-sem-typecheck",
  "version": "1.3.0",
  "private": true,
  "description": "BuildMaster Elite Mobile React Native/Expo: workflow simplificado para gerar APK sem travar em tsconfig antigo.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android --clean --no-install",
    "typecheck": "node scripts/check-tsconfig.js",
    "build:apk:debug": "npm run prebuild:android && cd android && ./gradlew assembleDebug",
    "fix:tsconfig": "node scripts/fix-tsconfig.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.39",
    "expo-image-picker": "~15.0.7",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
